# Database - PostgreSQL connection string
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/orbitAidb?schema=public"

# Session secret - used to sign session cookies (change this!)
SESSION_SECRET="change-me-to-a-random-string"

# NextAuth (used for auth)
NEXTAUTH_SECRET="change-me-to-a-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Replit ID (use "local-dev" for local development)
REPL_ID="local-dev"

# OpenAI API key (optional - for AI feedback features)
OPENAI_API_KEY="sk-your-key-here"
